{
  "name": "prettier-plugin-wgsl",
  "version": "0.1.8",
  "description": "Prettier plugin for WGSL (WebGPU Shading Language)",
  "author": "Abdullah Barhoum",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/AbdBarho/prettier-plugin-wgsl.git"
  },
  "type": "module",
  "main": "./dist/index.mjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.mts",
  "sideEffects": false,
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsdown",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "bench": "vitest bench",
    "bench:baseline": "vitest bench --outputJson bench.json",
    "bench:compare": "vitest bench --compare bench.json",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run build"
  },
  "prettier": {
    "printWidth": 140
  },
  "keywords": [
    "prettier",
    "prettier-plugin",
    "plugin",
    "wgsl",
    "webgpu",
    "gpu",
    "shading-language",
    "formatter",
    "format",
    "code-formatter"
  ],
  "peerDependencies": {
    "prettier": ">=3.0.0"
  },
  "dependencies": {
    "chevrotain": "^12.0.0"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "@vitest/coverage-v8": "^4.1.2",
    "prettier": "^3.8.2",
    "tsdown": "^0.21.7",
    "typescript": "^6.0.2",
    "vitest": "^4.0.7"
  }
}
